<?xml version="1.0" encoding="utf-8"?>
<!-- dotnet publish -c Release -p:PublishProfile=Win64-SingleFile -->
<!--
  Готовый exe: out\dist\VlessVPN.exe
  Не пишем в out\publish\: если оттуда запущен VlessVPN.exe, файл заблокирован → MSB4018 IOException при GenerateBundle.
  Своя папка: dotnet publish ... -p:PublishDir=out\mybuild\  (приложение из целевой папки должно быть закрыто)
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishDir>out\dist\</PublishDir>
  </PropertyGroup>
</Project>
