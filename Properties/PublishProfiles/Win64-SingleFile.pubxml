<?xml version="1.0" encoding="utf-8"?>
<!-- dotnet publish -c Release -p:PublishProfile=Win64-SingleFile -->
<!--
  Single-file пишется в out\publish-singlefile\ — не в out\dist\, иначе при запущенном VlessVPN.exe из out\dist
  получите MSB4018 (GenerateBundle не может перезаписать заблокированный файл).

  Готовый артефакт: out\publish-singlefile\VlessVPN.exe (+ xray-core рядом).
  Скопировать в out\dist для раздачи: закройте приложение, затем скопируйте папку или:
  robocopy out\publish-singlefile out\dist /E

  Свой каталог: dotnet publish ... -p:PublishDir=out\mybuild\
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishDir>out\publish-singlefile\</PublishDir>
  </PropertyGroup>
</Project>
