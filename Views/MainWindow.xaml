<Window x:Class="VlessVPN.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:VlessVPN.ViewModels"
        mc:Ignorable="d"
        Title="VlessVPN"
        Icon="pack://application:,,,/Assets/VlessVPN-icon.ico"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDarkBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#0F1923" Offset="0.5"/>
                <GradientStop Color="#0D1117" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decorative elements -->
        <Ellipse Width="600" Height="600" Opacity="0.03" 
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-200,-200,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#00D9FF" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="400" Height="400" Opacity="0.03" 
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-100,-100,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#2EA043" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Server List -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="🛡️ VlessVPN" FontSize="24" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentCyanBrush}"/>
                        <TextBlock Text="Secure Connection Client" FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Import Section -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" 
                                     Text="{Binding ImportUri, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="VLESS URI или URL подписки (сохраняется)..."
                                     Style="{StaticResource CompactOutlinedTextBox}"
                                     FontSize="12" Height="38"
                                     materialDesign:TextFieldAssist.HasClearButton="True"/>
                            <Button Grid.Column="1" Margin="8,0,0,0"
                                    Command="{Binding ImportFromUriCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="Импорт"
                                    Height="38" Width="38">
                                <materialDesign:PackIcon Kind="Import" Width="20" Height="20"/>
                            </Button>
                            <Button Grid.Column="2" Margin="4,0,0,0"
                                    Command="{Binding RefreshSubscriptionCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="Обновить подписку (тот же URL)"
                                    Height="38" Width="38">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                            </Button>
                        </Grid>
                        <Button Command="{Binding ImportFromClipboardCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="📋 Import from Clipboard"
                                Margin="0,8,0,0" Height="36" FontSize="12"/>
                    </StackPanel>

                    <!-- Server List -->
                    <ListBox Grid.Row="2" 
                             ItemsSource="{Binding Servers}"
                             SelectedItem="{Binding SelectedServer}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="Margin" Value="0,2"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" 
                                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="{Binding Address, Mode=OneWay}"/>
                                            <Run Text=":"/>
                                            <Run Text="{Binding Port, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Server Actions -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Command="{Binding AddServerCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Add Server">
                            <materialDesign:PackIcon Kind="Plus"/>
                        </Button>
                        <Button Command="{Binding RemoveServerCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Remove Server">
                            <materialDesign:PackIcon Kind="Delete"/>
                        </Button>
                        <Button Command="{Binding CopyServerUriCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Copy URI">
                            <materialDesign:PackIcon Kind="ContentCopy"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Connection Status Card -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <!-- Status Indicator -->
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource AccentCyanBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                            
                            <TextBlock Margin="24,8,0,0" FontSize="13" 
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Duration: "/>
                                <Run Text="{Binding ConnectionDuration}" FontWeight="SemiBold" 
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Connect Button -->
                        <Button Grid.Column="1" 
                                Command="{Binding ToggleConnectionCommand}"
                                Width="160" Height="56"
                                FontSize="16" FontWeight="SemiBold"
                                materialDesign:ButtonAssist.CornerRadius="28">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
                                    <Setter Property="Background" Value="{StaticResource AccentCyanBrush}"/>
                                    <Setter Property="Foreground" Value="#0D1117"/>
                                    <Setter Property="Content" Value="⚡ Connect"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Content" Value="⏹ Disconnect"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                            <Setter Property="Content" Value="⏳ Connecting..."/>
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Server Configuration -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                        Visibility="{Binding SelectedServer, Converter={StaticResource NullableToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Text="Server Configuration" 
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <!-- Row 1 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="Name" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedServer.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactOutlinedTextBox}" Height="38"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                            <TextBlock Text="Address" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedServer.Address, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactOutlinedTextBox}" Height="38"/>
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="Port" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedServer.Port, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactOutlinedTextBox}" Height="38"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12">
                            <TextBlock Text="UUID" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedServer.UserId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactOutlinedTextBox}" Height="38" FontSize="11"/>
                        </StackPanel>

                        <!-- Row 3 - Advanced Settings -->
                        <Expander Grid.Row="3" Grid.ColumnSpan="2" Header="Advanced Settings" 
                                  materialDesign:ExpanderAssist.HorizontalHeaderPadding="0"
                                  Background="Transparent" Margin="0,4,0,0">
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                    <TextBlock Text="Network" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValue="{Binding SelectedServer.Network}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource CompactOutlinedComboBox}" Height="38">
                                        <ComboBoxItem Content="tcp"/>
                                        <ComboBoxItem Content="ws"/>
                                        <ComboBoxItem Content="grpc"/>
                                        <ComboBoxItem Content="http"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,8,12">
                                    <TextBlock Text="Security" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValue="{Binding SelectedServer.Security}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource CompactOutlinedComboBox}" Height="38">
                                        <ComboBoxItem Content="tls"/>
                                        <ComboBoxItem Content="reality"/>
                                        <ComboBoxItem Content="none"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="8,0,0,12">
                                    <TextBlock Text="SNI" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SelectedServer.Sni, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="38"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                    <TextBlock Text="Flow" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValue="{Binding SelectedServer.Flow}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource CompactOutlinedComboBox}" Height="38" IsEditable="True">
                                        <ComboBoxItem Content="xtls-rprx-vision"/>
                                        <ComboBoxItem Content=""/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,8,12">
                                    <TextBlock Text="Fingerprint" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox SelectedValue="{Binding SelectedServer.Fingerprint}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource CompactOutlinedComboBox}" Height="38">
                                        <ComboBoxItem Content="chrome"/>
                                        <ComboBoxItem Content="firefox"/>
                                        <ComboBoxItem Content="safari"/>
                                        <ComboBoxItem Content="edge"/>
                                        <ComboBoxItem Content="random"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,0,0,12">
                                    <TextBlock Text="ALPN" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SelectedServer.Alpn, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="38"/>
                                </StackPanel>

                                <!-- Reality Settings -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Public Key (Reality)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SelectedServer.PublicKey, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="38" FontSize="10"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Short ID" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding SelectedServer.ShortId, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="38"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="8,0,0,0">
                                    <CheckBox Content="Allow Insecure (UNSAFE)"
                                              IsChecked="{Binding SelectedServer.AllowInsecure}"
                                              Foreground="#F85149"
                                              ToolTip="Allows invalid TLS certificates. Only enable for testing — exposes traffic to MITM attacks."
                                              Margin="0,0,0,4"/>
                                    <Button Command="{Binding SaveServerChangesCommand}"
                                            Content="💾 Save Changes"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Height="38"/>
                                </StackPanel>
                            </Grid>
                        </Expander>
                    </Grid>
                </Border>

                <!-- Log Output & Settings -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- Log Output -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="📝 Connection Log" FontSize="14" FontWeight="SemiBold"/>
                                <Button HorizontalAlignment="Right" 
                                        Command="{Binding ClearLogCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Width="24" Height="24" ToolTip="Clear Log">
                                    <materialDesign:PackIcon Kind="DeleteSweep" Width="16" Height="16"/>
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          x:Name="LogScrollViewer">
                                <TextBox Text="{Binding LogOutput, Mode=OneWay}" 
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Code, Consolas, Courier New"
                                         FontSize="11"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         VerticalScrollBarVisibility="Disabled"
                                         AcceptsReturn="True"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Settings Panel -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="⚙️ Settings" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <TextBlock Text="SOCKS5 Port" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CompactOutlinedTextBox}" 
                                         Height="38" Margin="0,0,0,12"/>

                                <TextBlock Text="HTTP Port" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding HttpPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CompactOutlinedTextBox}" 
                                         Height="38" Margin="0,0,0,12"/>

                                <CheckBox Content="System Proxy"
                                          IsChecked="{Binding EnableSystemProxy}"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          Margin="0,8,0,0"/>

                                <CheckBox Content="🔒 Cloudflare DNS (DoH)"
                                          IsChecked="{Binding EnableCloudflareDns}"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          ToolTip="Шифрование DNS через Cloudflare 1.1.1.1 (DNS over HTTPS)"
                                          Margin="0,8,0,0"/>

                                <Separator Margin="0,12"/>

                                <!-- Anti-DPI -->
                                <TextBlock Text="Anti-DPI" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <CheckBox Content="TLS Fragment"
                                          IsChecked="{Binding EnableTlsFragment}"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          ToolTip="Фрагментация TLS ClientHello для обхода DPI. Включите, если соединение блокируется."
                                          Margin="0,4,0,8"/>

                                <StackPanel Visibility="{Binding EnableTlsFragment, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Length range" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding TlsFragmentLength, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="34" FontSize="11" Margin="0,0,0,8"/>
                                    <TextBlock Text="Interval range (ms)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding TlsFragmentInterval, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="34" FontSize="11"/>
                                </StackPanel>

                                <Separator Margin="0,12"/>

                                <!-- WARP -->
                                <TextBlock Text="WARP (Cloudflare)" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <CheckBox Content="Enable WARP"
                                          IsChecked="{Binding EnableWarp}"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          ToolTip="Цепочка трафика через Cloudflare WARP после VLESS сервера. Помогает обходить блокировки по IP датацентра."
                                          Margin="0,4,0,8"/>

                                <StackPanel Visibility="{Binding EnableWarp, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Private Key" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding WarpPrivateKey, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="34" FontSize="10" Margin="0,0,0,8"/>

                                    <TextBlock Text="IPv4 Address" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding WarpAddressV4, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="34" FontSize="10" Margin="0,0,0,8"/>

                                    <TextBlock Text="IPv6 Address" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding WarpAddressV6, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="34" FontSize="10" Margin="0,0,0,8"/>

                                    <TextBlock Text="Reserved (e.g. 0,0,0)" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding WarpReserved, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="34" FontSize="10" Margin="0,0,0,8"/>

                                    <TextBlock Text="Endpoint" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding WarpEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource CompactOutlinedTextBox}" Height="34" FontSize="10"/>
                                </StackPanel>

                                <Separator Margin="0,12"/>

                                <!-- Force VPN: домены, которые ВСЕГДА через VPN -->
                                <CheckBox Content="🔒 Force VPN domains"
                                          IsChecked="{Binding EnableForceProxy}"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          ToolTip="Домены из этого списка ВСЕГДА идут через VPN, даже если попадают под bypass (domain:.ru, geoip:ru).&#x0a;Решает проблему: google.ru, YouTube CDN с российскими IP и т.п."
                                          Margin="0,4,0,8"/>

                                <TextBlock Text="Categories (click to toggle):" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"
                                           Visibility="{Binding EnableForceProxy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding ForceProxyCategoryToggles}"
                                              Margin="0,0,0,8"
                                              Visibility="{Binding EnableForceProxy, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ToggleButton Content="{Binding Display}"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          ToolTip="{Binding Tooltip}"
                                                          Style="{StaticResource CategoryChipToggle}"
                                                          Margin="0,0,4,4"
                                                          MinHeight="24"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Always VPN (one per line):" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"
                                           Visibility="{Binding EnableForceProxy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBox Text="{Binding ForceProxyDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="10"
                                         FontFamily="Cascadia Code, Consolas"
                                         Height="120"
                                         Style="{StaticResource CompactOutlinedTextBox}"
                                         ToolTip="Google, YouTube, Instagram, Claude и др. — всегда через VPN,&#x0a;даже если domain:.ru или geoip:ru хотят отправить напрямую."
                                         Visibility="{Binding EnableForceProxy, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Separator Margin="0,12"/>

                                <!-- Bypass Settings -->
                                <CheckBox Content="🔀 Bypass domains"
                                          IsChecked="{Binding EnableBypass}"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          ToolTip="Прямое подключение для указанных доменов (минуя VPN)"
                                          Margin="0,4,0,8"/>
                                
                                <TextBlock Text="Categories (click to toggle):" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"
                                           Visibility="{Binding EnableBypass, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding BypassCategoryToggles}"
                                              Margin="0,0,0,8"
                                              Visibility="{Binding EnableBypass, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ToggleButton Content="{Binding Display}"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          ToolTip="{Binding Tooltip}"
                                                          Style="{StaticResource CategoryChipToggle}"
                                                          Margin="0,0,4,4"
                                                          MinHeight="24"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Bypass list (one per line):" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"
                                           Visibility="{Binding EnableBypass, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBox Text="{Binding BypassDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="10"
                                         FontFamily="Cascadia Code, Consolas"
                                         Height="120"
                                         Style="{StaticResource CompactOutlinedTextBox}"
                                         ToolTip="domain:site.com — site.com и *.site.com&#x0a;regexp:.*\\.bongacams\\d+\\.com$ — bongacams21.com и т.п.&#x0a;geoip:private — локальные адреса"
                                         Visibility="{Binding EnableBypass, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Separator Margin="0,12"/>

                                <TextBlock Text="Proxy Address" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,4"/>
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas">
                                    <Run Text="SOCKS5: 127.0.0.1:"/>
                                    <Run Text="{Binding LocalPort}"/>
                                </TextBlock>
                                <TextBlock FontSize="10" FontFamily="Cascadia Code, Consolas" Margin="0,2,0,0">
                                    <Run Text="HTTP: 127.0.0.1:"/>
                                    <Run Text="{Binding HttpPort}"/>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

